{
	"compilerOptions": {
		"target": "es2020",
		"module": "commonjs",
		"resolveJsonModule": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true,
		"outDir": "dist"
	},
	"include": [
		"./hardhat.config.ts",
		"./scripts",
		"./test",
		"./typechain-types",
		"./src",
		"./deploy",
		"./sdk"
	]
}

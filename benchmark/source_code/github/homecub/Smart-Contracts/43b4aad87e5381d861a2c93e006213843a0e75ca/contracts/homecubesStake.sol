contract MaticzHomeCubeStaking is
    Initializable,
    OwnableUpgradeable,
    IERC721ReceiverUpgradeable,
    VerifySignature
{
    using SafeMathUpgradeable for uint256;
    struct propertyStack {
        uint256 tokenId;
        uint poolId;
        uint256 startPeriod;
        bool status;
        address owner;
    }
    struct poolInfo {
        uint256 lockPeriod;
        bool _enablestack;
    }
    mapping(uint => mapping(address => mapping(uint => propertyStack)))
        public stackitem;
    mapping(address => mapping(uint => bool)) public stackStaus;
    mapping(uint256 => uint256) public totalusersperpool;
    mapping(uint => poolInfo) public poolStatus;
    uint public poolCount;
    bool public enablestack;
    bool public emergencynftwithdraw;
    uint256 public deci;
    uint256 public totalstakeusers;
    address public rewardAddress;

    address public tradeAddress;
    string private message;

    function initialize() public initializer {
        __Ownable_init();
        enablestack = false;
        emergencynftwithdraw = false;
        poolCount = 0;
        deci = 18;
    }

    function nftStack(
        uint256 tokenId,
        uint _poolId,
        address _collectionAddress
    ) external {
        require(
            !stackitem[_poolId][_collectionAddress][tokenId].status,
            "This NFT Already Staked This Pool"
        );
        require(!stackStaus[_collectionAddress][tokenId], "NFT Already Staked");
        require(
            enablestack &&
                poolStatus[_poolId]._enablestack &&
                IERC721Upgradeable(_collectionAddress).ownerOf(tokenId) ==
                _msgSender(),
            "Stacking Not available"
        );
        IERC721Upgradeable(_collectionAddress).safeTransferFrom(
            _msgSender(),
            address(this),
            tokenId
        );
        propertyStack memory item;
        item.tokenId = tokenId;
        item.poolId = _poolId;
        item.startPeriod = block.timestamp;
        item.status = true;
        item.owner = _msgSender();
        stackitem[_poolId][_collectionAddress][tokenId] = item;
        stackStaus[_collectionAddress][tokenId] = true;
        totalstakeusers = totalstakeusers.add(1);
        totalusersperpool[_poolId] = totalusersperpool[_poolId].add(1);
    }
    function openStacking(bool option) external onlyOwner {
        enablestack = option;
    }
    function openemergencynftwithdraw(bool option) external onlyOwner {
        emergencynftwithdraw = option;
    }
    function nftWithdraw(
        uint256 tokenId,
        uint _poolId,
        address _collectionAddress
    ) external {
        require(
            stackitem[_poolId][_collectionAddress][tokenId].owner ==
                _msgSender(),
            "NFT withdraw NOT Available for This Address"
        );
        delete stackitem[_poolId][_collectionAddress][tokenId];
        delete stackStaus[_collectionAddress][tokenId];
        IERC721Upgradeable(_collectionAddress).safeTransferFrom(
            address(this),
            _msgSender(),
            tokenId
        );
        totalstakeusers = totalstakeusers.sub(1);
        totalusersperpool[_poolId] = totalusersperpool[_poolId].sub(1);
    }

    // lockPeriod - days * 1e18
    // poolid - if Create new pool 0 else Existing pool id
    // _enablestack - if pool available for stake true else false
    function editPool(
        uint256 lockPeriod,
        uint poolid,
        bool _enablestack
    ) external onlyOwner {
        if (poolid == 0) {
            poolInfo memory pool;
            pool.lockPeriod = lockPeriod;
            pool._enablestack = true;
            poolCount = poolCount.add(1);
            poolStatus[poolCount] = pool;
        } else {
            poolStatus[poolid]._enablestack = _enablestack;
        }
    }

    function emergencyWithdrawNFT(
        uint256 tokenId,
        uint _poolId,
        address _collectionAddress
    ) external {
        require(
            stackitem[_poolId][_collectionAddress][tokenId].owner ==
                _msgSender(),
            "NFT withdraw NOT Available for This Address"
        );
        require(emergencynftwithdraw == true, "NFT withdraw Not Available");
        IERC721Upgradeable(_collectionAddress).safeTransferFrom(
            address(this),
            _msgSender(),
            tokenId
        );
        delete stackitem[_poolId][_collectionAddress][tokenId];
        delete stackStaus[_collectionAddress][tokenId];
        totalstakeusers = totalstakeusers.sub(1);
        totalusersperpool[_poolId] = totalusersperpool[_poolId].sub(1);
    }
    function emergencyTokenWithdraw(
        uint256 amount
    ) external onlyOwner {
        require(
            IERC20Upgradeable(rewardAddress).balanceOf(
                address(this)
            ) >= amount,
            "Not Enought Token Balance"
        );
        IERC20Upgradeable(rewardAddress).transfer(
            _msgSender(),
            amount
        );
    }

    function claimReward(
        uint256 reward,
        uint _nonce,
        bytes memory signature
    ) external {
        require(bytes(message).length > 0, "Message is not set.");
        verify(owner(), reward, message, _nonce, signature);
        uint tdeci = deci.sub(IERC20Upgradeable(rewardAddress).decimals());
        IERC20Upgradeable(rewardAddress).transfer(
            _msgSender(),
            reward.div(10 ** tdeci)
        );
    }
    function addRewardToken(address _rewardAddr) external onlyOwner {
        rewardAddress = _rewardAddr;
    }
    function onERC721Received(
        address,
        address,
        uint256,
        bytes calldata
    ) external pure override returns (bytes4) {
        return IERC721ReceiverUpgradeable.onERC721Received.selector;
    }

    function editTradeAddress(address tradeAdd) external onlyOwner {
        tradeAddress = tradeAdd;
    }

    function setMessage(string memory _msg) external onlyOwner {
        message = _msg;
    }
}

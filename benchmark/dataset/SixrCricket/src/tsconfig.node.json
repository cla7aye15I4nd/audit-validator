{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node", "mocha", "chai", "bn.js", "pbkdf2"],
    "typeRoots": ["./types", "./node_modules/@types"]
  },
  "include": [
    "hardhat.config.ts",
    "deploy/**/*.ts",
    "types"
  ],
  "exclude": [
    "tasks/**",
    "test/**",
    "scripts/**",
    "layerzero.config.ts",
    "layerzero.simple-worker.config.ts",
    "deploy/SimpleDVNMock.ts"
  ]
}

      "post": {
        "summary": "approve tx",
        "operationId": "ManagerAPI_ApproveTx",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/tunnelapiApproveTxReply"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/tunnelapiApproveTxRequest"
            }
          }
        ],
        "tags": [
          "ManagerAPI"
        ]
      }
    },

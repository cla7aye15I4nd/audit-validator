{
	"compilerOptions": {
		"target": "ES2020",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"esModuleInterop": true,
		"strict": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"outDir": "./dist",
		"rootDir": "deploy",
		"sourceMap": true,
		"declaration": true,
		"resolveJsonModule": true
	},
	"include": ["deploy/**/*"],
	"exclude": ["node_modules", "dist"]
}
